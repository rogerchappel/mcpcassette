{
  "name": "@rogerchappel/mcpcassette",
  "version": "0.1.0",
  "description": "Record and replay MCP stdio JSON-RPC sessions as deterministic JSONL fixture cassettes.",
  "type": "module",
  "bin": {
    "mcpcassette": "./dist/src/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "mcp",
    "json-rpc",
    "fixtures",
    "cassette",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/mcpcassette.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/mcpcassette/issues"
  },
  "homepage": "https://github.com/rogerchappel/mcpcassette#readme"
}
